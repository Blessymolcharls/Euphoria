PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/euphoria
REDIS_URL=redis://localhost:6379

# Spotify Developer Dashboard: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Google Cloud Console - YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# Absolute path to yt-dlp executable (or just "yt-dlp" if in PATH)
YTDLP_PATH=yt-dlp
# Absolute path to ffmpeg (or just "ffmpeg" if in PATH)
FFMPEG_PATH=ffmpeg

# Directory to store downloaded audio files
DOWNLOADS_DIR=./downloads
